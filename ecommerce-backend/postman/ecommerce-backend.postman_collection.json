{
  "info": {
    "_postman_id": "ecommerce-backend-api",
    "name": "E-commerce Backend API",
    "description": "Postman collection for the Node.js/Express/MongoDB e-commerce backend.\n\n**Suggested test order:**\n1. Health Check\n2. Register User (or skip if already registered)\n3. Login User — saves `token` automatically\n4. Admin Login — use after running `npm run seed:admin` (admin@store.com / admin123)\n5. Create Product (admin) — saves `productId`\n6. Get All Products / Get Product by ID\n7. Create Order (user token) — saves `orderId`\n8. Get My Orders\n9. Get All Orders / Update Order Status (admin)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Verify the API server is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Creates a new user account. Returns 201 on success."
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('User token saved to collection variable: token');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Authenticates a user and returns a JWT. The token is auto-saved to the `token` collection variable."
          },
          "response": []
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('adminToken', json.token);",
                  "    console.log('Admin token saved to collection variable: adminToken');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@store.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Login as admin. Run `npm run seed:admin` first if the admin user does not exist."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const products = pm.response.json();",
                  "    if (Array.isArray(products) && products.length > 0) {",
                  "        pm.collectionVariables.set('productId', products[0]._id);",
                  "        console.log('productId set from first product:', products[0]._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products",
            "description": "Public endpoint. Returns all products sorted by newest first."
          },
          "response": []
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}",
            "description": "Public endpoint. Uses the `productId` collection variable."
          },
          "response": []
        },
        {
          "name": "Create Product (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('productId', pm.response.json()._id);",
                  "    console.log('productId saved:', pm.response.json()._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Headphones\",\n  \"description\": \"Noise-cancelling over-ear headphones with 30h battery life.\",\n  \"price\": 79.99,\n  \"stock\": 50\n}"
            },
            "url": "{{baseUrl}}/products",
            "description": "Admin only. Requires Bearer token from Login Admin."
          },
          "response": []
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Headphones Pro\",\n  \"description\": \"Updated description with improved sound quality.\",\n  \"price\": 89.99,\n  \"stock\": 45\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}",
            "description": "Admin only. Updates the product matching `productId`."
          },
          "response": []
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}",
            "description": "Admin only. Deletes the product matching `productId`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('orderId', pm.response.json()._id);",
                  "    console.log('orderId saved:', pm.response.json()._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"product_id\": \"{{productId}}\",\n      \"qty\": 2\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/orders",
            "description": "Authenticated user only. Decrements product stock and creates an order. Uses `productId` from collection variables."
          },
          "response": []
        },
        {
          "name": "Get My Orders",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/orders/my-orders",
            "description": "Returns orders for the currently logged-in user."
          },
          "response": []
        },
        {
          "name": "Get All Orders (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const orders = pm.response.json();",
                  "    if (Array.isArray(orders) && orders.length > 0) {",
                  "        pm.collectionVariables.set('orderId', orders[0]._id);",
                  "        console.log('orderId set from first order:', orders[0]._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/orders",
            "description": "Admin only. Returns all orders across all users."
          },
          "response": []
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Shipped\"\n}"
            },
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "description": "Admin only. Valid statuses: Pending, Shipped, Delivered."
          },
          "response": []
        }
      ]
    }
  ]
}
